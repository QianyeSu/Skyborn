        subroutine dbarot_growth_rate_1d(lat,u,max_growth,ier,nlat) ! in :growth_rate_kernels:growth_rate_kernels.f90
            integer, optional, check(len(lat)>=nlat), depend(lat) :: nlat=len(lat)
            double precision dimension(nlat), intent(in) :: lat
            double precision dimension(nlat), depend(nlat), intent(in) :: u
            double precision intent(out) :: max_growth

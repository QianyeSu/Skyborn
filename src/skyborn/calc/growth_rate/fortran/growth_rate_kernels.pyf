        end subroutine dbarot_growth_rate_1d

        ! signature : max_growth,ier = dbaroc_growth_rate_1d(u,theta,pressure,temperature,f_cor,beta,smooth_window,wavenumber_mode,wavenumber_count,zonal_length)
        subroutine dbaroc_growth_rate_1d(u,theta,pressure,temperature,f_cor,beta,smooth_window,wavenumber_mode,wavenumber_count,zonal_length,max_growth,ier,nlev) ! in :growth_rate_kernels:growth_rate_kernels.f90

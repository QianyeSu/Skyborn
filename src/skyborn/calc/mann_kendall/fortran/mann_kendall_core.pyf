python module mann_kendall_core ! in
    interface ! in :mann_kendall_core
        subroutine mk_score_var_batch(data,s_values,var_values,modified,ntime,nseries) ! in :mann_kendall_core:mann_kendall_core.f90
            integer optional, intent(hide), depend(data) :: ntime = shape(data,0)
            integer optional, intent(hide), depend(data) :: nseries = shape(data,1)
            double precision intent(in) :: data(ntime,nseries)

include LICENSE
include README.md
include pyproject.toml
include setup.py
recursive-include requirements *.txt

recursive-include src/skyborn *.py *.pyi *.pyx *.pxd *.pxi *.pyf *.f *.f90 *.c *.h meson.build
recursive-include src/skyborn/gridfill/tests/data *.npy

# Keep source distributions focused on buildable source files.
prune tests
prune src/skyborn/gridfill/tests
prune src/skyborn/windspharm/tests
prune src/skyborn/windspharm/examples

# Drop transient Meson build directories from source distributions.
prune src/skyborn/interp/build
prune src/skyborn/gridfill/build
prune src/skyborn/spharm/build
prune src/skyborn/calc/mann_kendall/build
prune src/skyborn/calc/GPI/build
prune src/skyborn/calc/growth_rate/build
prune src/skyborn/calc/geostrophic/build
prune src/skyborn/calc/troposphere/build
prune src/skyborn/plot/nclcurly_native/build

global-exclude __pycache__ *
global-exclude *.py[cod]
global-exclude *.so
global-exclude *.pyd
global-exclude *.dll
global-exclude *.dylib
global-exclude *.dll.a
global-exclude *.o
global-exclude *.obj
